# ── App ──────────────────────────────────────────────────────────────────────
# Postgres connection string (auto-set in Docker — only needed for local dev)
DATABASE_URL=postgresql://dogear:dogear@localhost:5432/dogear

# ── Ports ────────────────────────────────────────────────────────────────────
# Port DogEar listens on. Default: 630
# DOGEAR_PORT=630

# pgAdmin web UI port. Default: 5050
# DOGEAR_PGADMIN_PORT=5050

# Postgres is not exposed to the host by default.
# Uncomment the ports section in docker-compose.yml and set this to expose it:
# DOGEAR_DB_PORT=54320

# ── HTTPS (optional) ─────────────────────────────────────────────────────────
# The app runs on plain HTTP by default. HTTPS is required for the camera
# scanner to work on mobile. Options:
#
# 1. Point your existing reverse proxy (Nginx, Traefik, NPM) at port 630
#    and terminate TLS there — no extra config needed here.
#
# 2. Re-add the Caddy service from git history and set:
#    DOGEAR_HOST=my-server.tail1234.ts.net   (Tailscale)
#    DOGEAR_HOST=library.yourdomain.com      (real domain)
