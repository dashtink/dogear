# Postgres connection string (set automatically in Docker — only needed for local dev)
DATABASE_URL=postgresql://stackarr:stackarr@localhost:5432/stackarr

# Hostname for Caddy's HTTPS certificate.
# Leave unset for self-signed (local IP). Set to your Tailscale hostname or domain for trusted HTTPS.
# Examples:
#   STACKARR_HOST=my-server.tail1234.ts.net   (Tailscale)
#   STACKARR_HOST=library.yourdomain.com      (real domain)
# STACKARR_HOST=
